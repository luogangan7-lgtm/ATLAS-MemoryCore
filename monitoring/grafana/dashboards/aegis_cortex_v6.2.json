{
  "dashboard": {
    "id": null,
    "uid": "aegis-cortex-v6-2",
    "title": "Aegis-Cortex V6.2 监控面板",
    "tags": ["atlas", "memorycore", "aegis", "v6.2"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "系统概览",
        "type": "stat",
        "gridPos": {"h": 3, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=\"atlas-memorycore\"}",
            "legendFormat": "服务状态",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {"text": "离线", "color": "red"},
                  "1": {"text": "在线", "color": "green"}
                }
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "查询处理延迟",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 3},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(query_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95延迟",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(query_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50延迟",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3
          }
        }
      },
      {
        "id": 3,
        "title": "Token使用量",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 3},
        "targets": [
          {
            "expr": "rate(token_usage_total[5m])",
            "legendFormat": "Token使用率",
            "refId": "A"
          },
          {
            "expr": "token_cost_total",
            "legendFormat": "总成本",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 2
          }
        }
      },
      {
        "id": 4,
        "title": "缓存命中率",
        "type": "gauge",
        "gridPos": {"h": 5, "w": 6, "x": 0, "y": 11},
        "targets": [
          {
            "expr": "cache_hit_rate",
            "legendFormat": "命中率",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "orange", "value": 0.5},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "压缩率",
        "type": "gauge",
        "gridPos": {"h": 5, "w": 6, "x": 6, "y": 11},
        "targets": [
          {
            "expr": "compression_rate",
            "legendFormat": "压缩率",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "orange", "value": 0.5},
                {"color": "green", "value": 0.7}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "检索准确性",
        "type": "gauge",
        "gridPos": {"h": 5, "w": 6, "x": 12, "y": 11},
        "targets": [
          {
            "expr": "retrieval_accuracy",
            "legendFormat": "准确性",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "orange", "value": 0.7},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "内存使用",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"atlas-memorycore\"}",
            "legendFormat": "内存使用",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "min": 0
          }
        }
      },
      {
        "id": 8,
        "title": "QPS (每秒查询数)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(query_count_total[5m])",
            "legendFormat": "查询率",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 9,
        "title": "组件状态",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "component_status",
            "instant": true,
            "refId": "A"
          }
        ],
        "columns": [
          {"text": "组件", "value": "component"},
          {"text": "状态", "value": "status"},
          {"text": "版本", "value": "version"},
          {"text": "最后检查", "value": "last_check"}
        ]
      },
      {
        "id": 10,
        "title": "错误率",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "rate(error_count_total[5m]) / rate(query_count_total[5m])",
            "legendFormat": "错误率",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 11,
        "title": "模型使用分布",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "sum(model_usage_total) by (model)",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1,
    "links": [
      {
        "title": "API文档",
        "url": "http://localhost:8000/docs",
        "targetBlank": true
      },
      {
        "title": "Prometheus",
        "url": "http://localhost:9090",
        "targetBlank": true
      },
      {
        "title": "Qdrant管理",
        "url": "http://localhost:6333/dashboard",
        "targetBlank": true
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "部署事件",
          "datasource": "Prometheus",
          "enable": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "target": {
            "expr": "deployment_event",
            "legendFormat": "部署"
          }
        }
      ]
    }
  },
  "folderUid": "atlas-memorycore",
  "message": "Aegis-Cortex V6.2 监控面板",
  "overwrite": true
}