{
  "id": "atlas-memory",
  "name": "ATLAS Memory",
  "version": "10.0.0-phase10",
  "description": "自主演化知识系统 v10 — L0-L3四层 · 5Agent全自治 · INJECT层级优先 · 新鲜度衰减 · 分层Obsidian导出 · Git同步 · MCP Server(port 8765)",
  "main": "index.js",
