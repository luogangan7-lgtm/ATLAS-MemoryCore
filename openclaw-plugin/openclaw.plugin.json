  "configSchema": {
    "type": "object",
    "properties": {
      "qdrant_url": {
        "type": "string",
        "description": "Qdrant HTTP URL，默认 http://127.0.0.1:6333"
      },
      "collection": {
        "type": "string",
        "description": "Qdrant collection 名，默认 atlas_memories"
      },
      "ollama_url": {
        "type": "string",
        "description": "Ollama HTTP URL，默认 http://127.0.0.1:11434"
      },
      "embed_model": {
        "type": "string",
        "description": "嵌入模型，默认 nomic-embed-text:latest"
      }
    }
  }
}