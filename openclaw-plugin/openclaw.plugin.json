{
  "id": "atlas-memory",
  "name": "ATLAS Memory",
  "version": "9.4.0",
  "description": "商业级语义记忆系统 — Qdrant + Ollama nomic-embed + omlx Qwen3.5 冲突检测 + 质量过滤 + memory_type + Obsidian Bridge",
  "main": "index.js",
  "author": "ATLAS Team",
  "license": "MIT",
  "configSchema": {
    "type": "object",
    "properties": {
      "qdrant_url": { "type": "string", "description": "Qdrant HTTP URL，默认 http://127.0.0.1:6333" },
      "collection": { "type": "string", "description": "Qdrant collection 名，默认 atlas_memories" },
      "ollama_url": { "type": "string", "description": "Ollama HTTP URL，默认 http://127.0.0.1:11434" },
      "embed_model": { "type": "string", "description": "嵌入模型，默认 nomic-embed-text:latest" }
    }
  }
}
